# ============================================
# SHIFTSYNC ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and customize for your environment.
# Lines starting with # are comments and will be ignored.

# ============================================
# DJANGO SETTINGS
# ============================================

# Secret key for cryptographic signing (REQUIRED)
# Used for session cookies, CSRF tokens, password reset tokens, etc.
# SECURITY: Generate a unique key for production - never share or commit!
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Dev example:  django-insecure-dev-key-change-in-production
# Prod example: your-50-character-random-string-here
SECRET_KEY=your-secret-key-here

# Debug mode (REQUIRED)
# Enables detailed error pages and debug toolbar in development.
# SECURITY: Must be False in production to avoid exposing sensitive info!
# Dev:  True
# Prod: False
DEBUG=True

# Allowed hosts (REQUIRED for production)
# Comma-separated list of hostnames/domains that can serve the application.
# Dev example:  localhost,127.0.0.1
# Prod example: shiftsync.example.com,www.shiftsync.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# DATABASE
# ============================================

# Database connection URL (REQUIRED for production)
# SQLite is used by default in development (no configuration needed).
# For production, use PostgreSQL with a DATABASE_URL connection string.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE_NAME
# Dev:  (leave unset to use SQLite)
# Prod: postgres://shiftsync_user:secure_password@localhost:5432/shiftsync_db
DATABASE_URL=postgres://user:password@localhost:5432/shiftsync

# ============================================
# EMAIL CONFIGURATION
# ============================================

# Email backend class (REQUIRED)
# Determines how emails are sent. Console backend prints to terminal (dev).
# Dev:  django.core.mail.backends.console.EmailBackend
# Prod: django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP server hostname (REQUIRED for production SMTP)
# The hostname of your email provider's SMTP server.
# SendGrid:   smtp.sendgrid.net
# Mailgun:    smtp.mailgun.org
# Gmail:      smtp.gmail.com
# Amazon SES: email-smtp.us-east-1.amazonaws.com
EMAIL_HOST=smtp.example.com

# SMTP server port (REQUIRED for production SMTP)
# Common ports: 587 (TLS/STARTTLS), 465 (SSL), 25 (unencrypted - not recommended)
# Most providers: 587
EMAIL_PORT=587

# Use TLS encryption (REQUIRED for production SMTP)
# Enable TLS for secure email transmission. Recommended for port 587.
# Set to False only if using port 465 with EMAIL_USE_SSL=True
EMAIL_USE_TLS=True

# SMTP authentication username (REQUIRED for production SMTP)
# Your email provider's authentication username.
# SendGrid: apikey (literal string)
# Mailgun:  postmaster@your-domain.mailgun.org
# Gmail:    your-email@gmail.com
EMAIL_HOST_USER=

# SMTP authentication password (REQUIRED for production SMTP)
# Your email provider's authentication password or API key.
# SECURITY: Use environment variables or secrets management in production!
# SendGrid: Your SendGrid API key
# Mailgun:  Your Mailgun SMTP password
# Gmail:    App-specific password (not your regular password)
EMAIL_HOST_PASSWORD=

# Default sender email address (REQUIRED)
# The "From" address for all outgoing emails.
# Format: Display Name <email@domain.com>
# Dev example:  ShiftSync <noreply@localhost>
# Prod example: ShiftSync <noreply@shiftsync.example.com>
DEFAULT_FROM_EMAIL=ShiftSync <noreply@shiftsync.example.com>

# ============================================
# TIMEZONE
# ============================================

# Application timezone (OPTIONAL, defaults to UTC)
# Used for displaying dates/times and scheduling shift reminders.
# Must be a valid IANA timezone identifier.
# Examples: America/New_York, America/Los_Angeles, Europe/London, Asia/Tokyo
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIME_ZONE=America/New_York
